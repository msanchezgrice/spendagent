{
  "name": "agentspend",
  "version": "0.1.0",
  "description": "Local AI/API spend auditor for codebases — scans repos for LLM usage, imports usage data, and generates a ranked cost-savings report.",
  "type": "module",
  "bin": {
    "agentspend": "dist/cli/index.js"
  },
  "main": "dist/cli/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "agentspend": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "test -f dist/cli/index.js || npm run build"
  },
  "files": [
    "dist",
    "skills",
    "README.md"
  ],
  "keywords": [
    "ai",
    "llm",
    "cost",
    "audit",
    "cli",
    "openai",
    "anthropic",
    "spend",
    "fincoops"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "csv-parse": "^5.5.6",
    "fast-glob": "^3.3.2",
    "ignore": "^5.3.1",
    "ora": "^8.0.1",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.0"
  }
}
